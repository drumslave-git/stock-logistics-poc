# Copy to .env.local for local development. Never commit real values —
# .env.local is gitignored. In CI these come from GitHub Actions secrets.

# Google Maps JavaScript API key, referrer-restricted to the app's origins.
# Optional: map views degrade to a static fallback when this is absent.
VITE_GOOGLE_MAPS_API_KEY=

# SHA-256 hex of the shared access token that gates the deployed app.
# Empty = access gate disabled (open) for local dev.
# Generate with:  npm run hash-token -- "your-shared-token"
VITE_ACCESS_TOKEN_HASH=
